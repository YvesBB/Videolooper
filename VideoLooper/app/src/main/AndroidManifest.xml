<?xml version="1.0" encoding="utf-8"?>
<!--
  Note AGP 8+ : si tu utilises un build.gradle récent, l'attribut "package"
  ci-dessous est ignoré au profit de "namespace 'com.example.videolooper'"
  dans build.gradle. Garde les deux cohérents avec le package de MainActivity.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.videolooper">

    <!-- Android 6..10 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Android 11+ : accès direct à un fichier hors dossiers média (racine du stockage) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <!-- Android 13+ : accès média vidéo granulaire (utile si le fichier est indexé) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:label="VideoLooper"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
