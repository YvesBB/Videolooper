<?xml version="1.0" encoding="utf-8"?>
<!--
  Note AGP 8+ : si tu utilises un build.gradle récent, l'attribut "package"
  ci-dessous est ignoré au profit de "namespace 'com.example.videolooper'"
  dans build.gradle. Garde les deux cohérents avec le package de MainActivity.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.videolooper">

    <!-- Android 6..10 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Android 11+ : accès direct à un fichier hors dossiers média (racine du stockage) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <!-- Android 13+ : accès média vidéo granulaire (utile si le fichier est indexé) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Permet d'ajuster le volume média au démarrage -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Démarrage automatique au boot de l'appareil -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="VideoLooper"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OPTION LANCEUR (méthode la plus fiable pour un kiosque) :
                 décommente ce bloc pour pouvoir définir l'app comme écran
                 d'accueil. Au boot, Android lance le Home -> l'app démarre
                 seule, et se relance si elle est fermée.
				  -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
           
        </activity>

        <!-- Démarrage automatique au boot (méthode receiver) -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
