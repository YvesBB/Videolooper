<?xml version="1.0" encoding="utf-8"?>
<!--
  Note AGP 8+ : si ton build.gradle récent utilise "namespace 'com.videolooper'",
  l'attribut "package" ci-dessous est ignoré. Garde les deux identiques.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.videolooper">

    <!-- Android 6 : seule permission utile ici (demandée à l'exécution) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Ajuste le volume média au démarrage -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Démarrage automatique au boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Permissions inutiles sur Android 6, mais sans effet négatif si tu
         installes un jour sur un appareil plus récent (Android 11+ / 13+) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:label="VideoLooper"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OPTION LANCEUR (non nécessaire sur Android 6) :
                 décommente seulement si tu veux que l'app devienne l'écran
                 d'accueil. Inutile ici, le receiver suffit.
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            -->
        </activity>

        <!-- Démarrage automatique au boot -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
